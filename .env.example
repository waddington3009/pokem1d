# Copie para .env e preencha. NUNCA versione o .env real.

# Token do bot (Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=coloque_seu_token_aqui

# Prefixo padrão (cada servidor pode sobrescrever via comando admin)
DEFAULT_PREFIX=p!

# Banco de dados.
#   Dev/local (default):   sqlite+aiosqlite:///pokebot.db
#   Produção (Postgres):   postgresql+asyncpg://user:senha@host:5432/pokebot
DATABASE_URL=sqlite+aiosqlite:///pokebot.db

# IDs de donos do bot (separados por vírgula) — acesso a comandos owner
OWNER_IDS=

# Idioma padrão das mensagens do bot (pt | en)
DEFAULT_LANGUAGE=pt
